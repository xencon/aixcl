# Auto detect text files and perform LF normalization
* text=auto

# Force LF line endings for common text files
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.py text eol=lf
*.sql text eol=lf
*.conf text eol=lf
*.config text eol=lf
*.ini text eol=lf

# Mark binary files (do not convert line endings)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.bz2 binary
*.7z binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary

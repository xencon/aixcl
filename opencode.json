{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "DEVELOPMENT.md",
    "ai/skills/ascii_output.md"
  ],
  "permission": {
    "bash": {
      "*": "ask",
      "git status": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git add *": "allow",
      "git commit *": "ask",
      "git push origin main": "deny",
      "git push *": "ask",
      "grep *": "allow",
      "cat *": "allow",
      "ls *": "allow",
      "gh repo *": "allow",
      "gh issue *": "allow",
      "gh pr create *": "ask",
      "gh pr edit *": "ask",
      "gh pr merge *": "deny",
      "gh pr close *": "ask",
      "gh api *": "ask",
      "./aixcl *": "ask"
    },
    "edit": "ask",
    "webfetch": "ask"
  },
  "provider": {
    "aixcl-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "AIXCL",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {}
    }
  },
  "model": "aixcl-local/"
}

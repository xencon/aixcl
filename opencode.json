{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "DEVELOPMENT.md",
    "ai/governance/workflow-governance.md",
    "docs/architecture/governance/00_invariants.md",
    "docs/architecture/governance/01_ai_guidance.md",
    "docs/developer/development-workflow.md",
    "ai/actions/*.md"
  ],
  "default_agent": "agent-context",
  "agent": {
    "agent-context": {
      "mode": "primary",
      "description": "AIXCL primary agent with full project context and Issue-First workflow governance",
      "prompt": "{file:.opencode/agents/agent-context.md}",
      "permission": {
        "read": "allow",
        "edit": "ask",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git add*": "allow",
          "ls*": "allow",
          "cat*": "allow",
          "grep*": "allow",
          "gh repo*": "allow",
          "gh issue*": "allow",
          "git commit*": "ask",
          "git push*": "ask",
          "rm -rf*": "deny",
          "git push --force*": "deny",
          "./scripts/checks/check-agents.sh*": "allow"
        },
        "webfetch": "ask"
      }
    }
  },
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git add*": "allow",
      "ls*": "allow",
      "cat*": "allow",
      "grep*": "allow",
      "gh repo*": "allow",
      "gh issue*": "allow",
      "git commit*": "ask",
      "git push*": "ask",
      "rm -rf*": "deny",
      "git push --force*": "deny"
    },
    "webfetch": "ask"
  },
  "provider": {
    "aixcl-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "AIXCL",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "Qwen/Qwen2.5-Coder-0.5B-Instruct": {
          "name": "Qwen/Qwen2.5-Coder-0.5B-Instruct"
        }
      }
    }
  },
  "model": "aixcl-local/Qwen/Qwen2.5-Coder-0.5B-Instruct"
}

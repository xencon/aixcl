# Developer workstation profile
# UI + DB + admin tools

# Profile metadata
PROFILE_NAME=dev
PROFILE_DESCRIPTION="Developer workstation (UI + DB + admin tools)"

# Services included in this profile
PROFILE_SERVICES="$INFERENCE_ENGINE open-webui postgres pgadmin"

# Database storage enabled
ENABLE_DB_STORAGE=true


# User-oriented runtime profile
# Minimal footprint with database persistence

# Profile metadata
PROFILE_NAME=usr
PROFILE_DESCRIPTION="User-oriented runtime (minimal footprint with database persistence)"

# Services included in this profile
PROFILE_SERVICES="$INFERENCE_ENGINE postgres"

# Database storage enabled
ENABLE_DB_STORAGE=true

# Optional: Default model for this profile
# DEFAULT_MODEL=llama3.1:latest

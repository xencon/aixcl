# Observability-focused profile
# Monitoring/logging stack

# Profile metadata
PROFILE_NAME=ops
PROFILE_DESCRIPTION="Observability-focused (monitoring/logging)"

# Services included in this profile
PROFILE_SERVICES="$INFERENCE_ENGINE postgres prometheus grafana loki alloy cadvisor node-exporter postgres-exporter nvidia-gpu-exporter"

# Database storage enabled
ENABLE_DB_STORAGE=true

# Optional: Default model for this profile
# DEFAULT_MODEL=prometheus-optimized:latest

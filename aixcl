function add() {
    if [ -z "$1" ]; then
        echo "Error: Model name is required"
        echo "Usage: $0 models add <model-name> [<model-name> ...]"
        return 1
    fi

    # Validate model name format (allowing slashes for HF models)
    if [[ ! "$1" =~ ^[A-Za-z0-9._/-]+(:[A-Za-z0-9._-]+)?$ ]]; then
        echo -e "\xe2\x9d\x8c Invalid model name format: '$1'"
        echo "   Model names should contain only alphanumeric characters, dots, underscores, dashes, and slashes"
        echo "   Optional tag format: model:tag (e.g., Qwen/Qwen2.5-0.5B-Instruct)"
        return 1
    fi

    echo "Adding model: $1"
    
    local engine="${INFERENCE_ENGINE:-ollama}"
    local container
    container=$(get_engine_container "$engine")
    
    # Check if we should update compose file (vLLM and llama.cpp set model at startup)
    if [[ "$engine" == "vllm" || "$engine" == "llamacpp" ]]; then
        local compose_file="services/docker-compose.yml"
        if [ ! -f "$compose_file" ]; then
             echo "❌ Error: $compose_file not found."
             return 1
        fi
        
        echo "🔄 Updating $engine configuration in $compose_file to use model: $1"
        if [[ "$engine" == "vllm" ]]; then
            # Update vllm model in command array
            sed -i "/vllm:/,/healthcheck:/s|command:.*|command: [\"--model\", \"$1\", \"--gpu-memory-utilization\", \"0.8\"]|" "$compose_file"
        elif [[ "$engine" == "llamacpp" ]]; then
            # Update llamacpp model path. Assuming models are in /models/ internally
            sed -i "/llamacpp:/,/healthcheck:/s|command:.*|command: [\"-m\", \"/models/$1\", \"--host\", \"0.0.0.0\", \"--port\", \"8080\"]|" "$compose_file"
        fi
        echo "✅ Configuration updated. Please restart the stack to apply changes: $0 stack restart"
        return 0
    fi

    # Standard pull for Ollama
    if [ -z "$container" ]; then
        echo "Error: $engine container is not running. Please start the services first."
        return 1
    fi

    if [ "$engine" = "ollama" ]; then
        if docker exec "$container" ollama pull "$1"; then
            echo "✅ Successfully added model: $1"
        else
            echo "❌ Failed to add model: $1"
            return 1
        fi
    else
        echo "⚠️  Model management for $engine is not fully automated yet."
    fi
}

function remove() {
    if [ -z "$1" ]; then
        echo "Error: Model name is required"
        echo "Usage: $0 models remove <model-name> [<model-name> ...]"
        return 1
    fi

    # Validate model name format
    if [[ ! "$1" =~ ^[A-Za-z0-9._/-]+(:[A-Za-z0-9._-]+)?$ ]]; then
        echo -e "\xe2\x9d\x8c Invalid model name format: '$1'"
        return 1
    fi

    echo "Removing model: $1"
    
    local engine="${INFERENCE_ENGINE:-ollama}"
    local container
    container=$(get_engine_container "$engine")
    
    if [ "$engine" = "ollama" ]; then
        if [ -z "$container" ]; then
            echo "Error: $engine container is not running. Please start the services first."
            return 1
        fi
        if docker exec "$container" ollama rm "$1"; then
            echo "✅ Successfully removed model: $1"
        else
            echo "❌ Failed to remove model: $1"
            return 1
        fi
    elif [[ "$engine" == "vllm" || "$engine" == "llamacpp" ]]; then
        echo "ℹ️  Model removal for $engine must be handled manually by removing files from volumes."
        echo "   vLLM/llama.cpp do not support a 'pull-style' removal command via CLI."
    else
        echo "⚠️  Model management for $engine is not fully automated yet."
    fi
}
function models() {
    if [[ $# -lt 1 ]]; then
        echo "Error: Models action is required"
        echo "Usage: $0 models {add|remove|list} [<model-name> ...]"
        echo "Examples:"
        echo "  $0 models add starcoder2:latest"
        echo "  $0 models remove starcoder2:latest nomic-embed-text:latest"
        echo "  $0 models list"
        return 1
    fi

    local action="$1"
    shift

    local status=0

    case "$action" in
        add)
            if [[ $# -lt 1 ]]; then
                echo "Error: At least one model name is required for add"
                echo "Usage: $0 models add <model-name> [<model-name> ...]"
                return 1
            fi
            for model in "$@"; do
                if ! add "$model"; then
                    status=1
                fi
            done
            # Refresh Continue CLI config so new models are available in cn
            if command -v continue_config >/dev/null 2>&1; then
                continue_config || true
            else
                echo "ℹ️  Continue CLI 'continue_config' not found, skipping sync."
            fi
            ;;
        remove)
            if [[ $# -lt 1 ]]; then
                echo "Error: At least one model name is required for remove"
                echo "Usage: $0 models remove <model-name> [<model-name> ...]"
                return 1
            fi
            for model in "$@"; do
                if ! remove "$model"; then
                    status=1
                fi
            done
            ;;
        list)
            if [[ $# -gt 0 ]]; then
                echo "Error: Unknown argument '$1'"
                echo "Usage: $0 models {add|remove|list} [<model-name> ...]"
                return 1
            fi
            list
            ;;
        *)
            echo "Error: Unknown models action '$action'"
            echo "Usage: $0 models {add|remove|list} [<model-name> ...]"
            return 1
            ;;
    esac

    return $status
}

function list() {
    local engine="${INFERENCE_ENGINE:-ollama}"
    echo "Listing installed models for $engine..."
    
    local container
    container=$(get_engine_container "$engine")
    
    if [ -z "$container" ]; then
        echo "Error: $engine container is not running. Please start the services first."
        return 1
    fi

    if [ "$engine" = "ollama" ]; then
        docker exec "$container" ollama list
    else
        # For vLLM and llama.cpp, try to use the OpenAI compatible API
        local url="http://localhost:11434/v1/models"
        if command -v curl >/dev/null 2>&1; then
            echo "API Models:"
            curl -s "$url" | grep -oP '"id":\s*"\K[^"]+' | sort -u || echo "⚠️  Could not retrieve models via API. Is the service ready?"
        else
            echo "⚠️  Curl not found. Cannot retrieve model list from API."
        fi
    fi
}

function open_url_in_browser() {
    local url="$1"

    if command -v xdg-open &> /dev/null; then
        xdg-open "$url" 2>/dev/null &
    elif command -v open &> /dev/null; then
        open "$url" 2>/dev/null &
    else
        echo "⚠️  Could not detect default browser. Please open $url manually."
    fi
}

function config_cmd() {
    local action="${1:-}"
    case "$action" in
        engine)
            shift
            local subaction="${1:-}"
            if [ "$subaction" = "set" ]; then
                local engine="${2:-}"
                if [[ "$engine" != "ollama" && "$engine" != "vllm" && "$engine" != "llamacpp" ]]; then
                    echo "❌ Error: Invalid engine '$engine'"
                    echo "Valid options: ollama, vllm, llamacpp"
                    return 1
                fi
                
                # Check if .env exists, if not use .env.example
                if [ ! -f "${SCRIPT_DIR}/.env" ] && [ -f "${SCRIPT_DIR}/.env.example" ]; then
                    cp "${SCRIPT_DIR}/.env.example" "${SCRIPT_DIR}/.env"
                fi
                
                if grep -q "^INFERENCE_ENGINE=" "${SCRIPT_DIR}/.env" 2>/dev/null; then
                    sed -i "s/^INFERENCE_ENGINE=.*/INFERENCE_ENGINE=$engine/" "${SCRIPT_DIR}/.env"
                else
                    echo "INFERENCE_ENGINE=$engine" >> "${SCRIPT_DIR}/.env"
                fi
                echo "✅ Inference engine set to: $engine"
                echo "Note: Stop and start the stack for the change to take effect."
            elif [ "$subaction" = "auto" ]; then
                # Check if .env exists, if not use .env.example
                if [ ! -f "${SCRIPT_DIR}/.env" ] && [ -f "${SCRIPT_DIR}/.env.example" ]; then
                    cp "${SCRIPT_DIR}/.env.example" "${SCRIPT_DIR}/.env"
                fi
                
                if has_nvidia; then
                    echo "NVIDIA GPU detected. Setting engine to vLLM for optimized performance."
                    if grep -q "^INFERENCE_ENGINE=" "${SCRIPT_DIR}/.env" 2>/dev/null; then
                        sed -i "s/^INFERENCE_ENGINE=.*/INFERENCE_ENGINE=vllm/" "${SCRIPT_DIR}/.env"
                    else
                        echo "INFERENCE_ENGINE=vllm" >> "${SCRIPT_DIR}/.env"
                    fi
                elif is_arm64; then
                    echo "Apple Silicon / ARM64 detected. Setting engine to llama.cpp for optimized performance."
                    if grep -q "^INFERENCE_ENGINE=" "${SCRIPT_DIR}/.env" 2>/dev/null; then
                        sed -i "s/^INFERENCE_ENGINE=.*/INFERENCE_ENGINE=llamacpp/" "${SCRIPT_DIR}/.env"
                    else
                        echo "INFERENCE_ENGINE=llamacpp" >> "${SCRIPT_DIR}/.env"
                    fi
                else
                    echo "No dedicated GPU detected. Setting engine to Ollama."
                    if grep -q "^INFERENCE_ENGINE=" "${SCRIPT_DIR}/.env" 2>/dev/null; then
                        sed -i "s/^INFERENCE_ENGINE=.*/INFERENCE_ENGINE=ollama/" "${SCRIPT_DIR}/.env"
                    else
                        echo "INFERENCE_ENGINE=ollama" >> "${SCRIPT_DIR}/.env"
                    fi
                fi
                echo "Note: Stop and start the stack for the change to take effect."
            else
                echo "Usage: ./aixcl config engine {set <engine>|auto}"
                echo "  set   - Manually set engine (ollama, vllm, llamacpp)"
                echo "  auto  - Auto-detect optimal engine based on hardware"
                return 1
            fi
            ;;
        *)
            echo "Error: Unknown config action '$action'"
            echo "Usage: ./aixcl config {engine}"
            return 1
            ;;
    esac
}



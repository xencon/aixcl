{
  "title": "FTSO Price Accuracy",
  "uid": "ftso-accuracy",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "tags": [
    "ftso",
    "flare",
    "oracle"
  ],
  "templating": {
    "list": [
      {
        "name": "pair",
        "label": "Pair",
        "type": "query",
        "datasource": {
          "type": "prometheus"
        },
        "query": "label_values(ftso_provider_price, pair)",
        "multi": false,
        "includeAll": false,
        "current": {
          "text": "BTC/USD",
          "value": "BTC/USD"
        }
      },
      {
        "name": "source",
        "label": "Reference",
        "type": "custom",
        "query": "coingecko,binance",
        "multi": false,
        "includeAll": false,
        "current": {
          "text": "coingecko",
          "value": "coingecko"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "% Pairs in Primary Band \u2014 CoinGecko",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "green",
                "value": 75
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "ftso_pairs_within_primary_band_pct{source=\"coingecko\"}",
          "legendFormat": "CoinGecko"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "% Pairs in Primary Band \u2014 Binance",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "green",
                "value": 75
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "ftso_pairs_within_primary_band_pct{source=\"binance\"}",
          "legendFormat": "Binance"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Provider Pairs Active",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "green",
                "value": 60
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "ftso_provider_prices_total",
          "legendFormat": "Pairs"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Poll Success Rate",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.9
              },
              {
                "color": "green",
                "value": 0.99
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "rate(ftso_poll_total{status=\"success\"}[5m]) / rate(ftso_poll_total[5m])",
          "legendFormat": "Success rate"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Reference Source Coverage",
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value_and_name",
        "colorMode": "none",
        "orientation": "vertical"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "ftso_reference_prices_total{source=\"coingecko\"}",
          "legendFormat": "CoinGecko"
        },
        {
          "expr": "ftso_reference_prices_total{source=\"binance\"}",
          "legendFormat": "Binance"
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Deviation History \u2014 $pair ($source reference)",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 16,
        "h": 8
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 3,
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "ftso_price_deviation_pct{pair=\"$pair\", source=\"$source\"}",
          "legendFormat": "deviation %"
        }
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Price Comparison \u2014 $pair",
      "gridPos": {
        "x": 16,
        "y": 4,
        "w": 8,
        "h": 8
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 6,
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "ftso_provider_price{pair=\"$pair\"}",
          "legendFormat": "Provider"
        },
        {
          "expr": "ftso_reference_price{pair=\"$pair\", source=\"coingecko\"}",
          "legendFormat": "CoinGecko"
        },
        {
          "expr": "ftso_reference_price{pair=\"$pair\", source=\"binance\"}",
          "legendFormat": "Binance"
        }
      ]
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "% Pairs Within Primary Band Over Time",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 7
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "green",
                "value": 75
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "ftso_pairs_within_primary_band_pct{source=\"coingecko\"}",
          "legendFormat": "CoinGecko"
        },
        {
          "expr": "ftso_pairs_within_primary_band_pct{source=\"binance\"}",
          "legendFormat": "Binance"
        }
      ]
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Reference Fetch Errors / 5m",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 7
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "increase(ftso_reference_fetch_errors_total[5m])",
          "legendFormat": "{{source}} errors"
        }
      ]
    }
  ]
}
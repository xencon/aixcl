{
  "title": "AIXCL - FTSO Feed Monitor",
  "uid": "ftso-accuracy",
  "schemaVersion": 38,
  "version": 1004,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "tags": [
    "ftso",
    "flare",
    "oracle"
  ],
  "templating": {
    "list": [
      {
        "name": "pair",
        "label": "Pair",
        "type": "query",
        "datasource": {
          "type": "prometheus"
        },
        "query": "label_values(ftso_provider_price, pair)",
        "multi": false,
        "includeAll": false,
        "current": {
          "text": "BTC/USD",
          "value": "BTC/USD"
        }
      },
      {
        "name": "source",
        "label": "Reference",
        "type": "custom",
        "query": "anchor,coingecko,binance",
        "multi": false,
        "includeAll": false,
        "current": {
          "text": "anchor",
          "value": "anchor"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "% Pairs in Band \u2014 CoinGecko",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "background",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "green",
                "value": 75
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "ftso_pairs_within_primary_band_pct{source=\"coingecko\"}",
          "legendFormat": "CoinGecko"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "% Pairs in Band \u2014 Binance",

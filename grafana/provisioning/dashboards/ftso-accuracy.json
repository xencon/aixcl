    {
      "id": 10,
      "type": "table",
      "title": "Live Accuracy \u2014 All Pairs",
      "description": "Anchor Dev% = deviation from the on-chain FTSOv2 median (your actual scoring reference). CG Dev% and Binance Dev% are external sanity checks. Green = within \u00b10.25%, Red = outside.",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 14
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Anchor Dev%",
            "desc": true
          }
        ],
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 3
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Anchor Dev%"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "decimals",
                "value": 3
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": -0.25
                    },
                    {
                      "color": "red",
                      "value": 0.25
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "CG Dev%"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "decimals",
                "value": 3
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": -0.25
                    },
                    {
                      "color": "red",
                      "value": 0.25
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Binance Dev%"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "decimals",
                "value": 3
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": -0.25
                    },
                    {
                      "color": "red",
                      "value": 0.25
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Provider Price"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              },
              {
                "id": "decimals",
                "value": 6
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": 1e-06
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "pair"
          }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "pattern": "^(pair|Value #anchor_dev|Value #cg_dev|Value #binance_dev|Value #provider)$"
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #anchor_dev": "Anchor Dev%",
              "Value #cg_dev": "CG Dev%",
              "Value #binance_dev": "Binance Dev%",
              "Value #provider": "Provider Price"
            },
            "indexByName": {
              "pair": 0,
              "Value #anchor_dev": 1,
              "Value #cg_dev": 2,
              "Value #binance_dev": 3,
              "Value #provider": 4
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "ftso_price_deviation_pct{source=\"anchor\"}",
          "instant": true,
          "format": "table",
          "refId": "anchor_dev"
        },
        {
          "expr": "ftso_price_deviation_pct{source=\"coingecko\"}",
          "instant": true,
          "format": "table",
          "refId": "cg_dev"
        },
        {
          "expr": "ftso_price_deviation_pct{source=\"binance\"}",
          "instant": true,
          "format": "table",
          "refId": "binance_dev"
        },
        {
          "expr": "ftso_provider_price",
          "instant": true,
          "format": "table",
          "refId": "provider"

        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #weight": "Weight",
              "Value #staleness": "Staleness",
              "Value #rawprice": "Raw Price"
            },
            "indexByName": {
              "pair": 0,
              "exchange": 1,
              "Weight": 2,
              "Staleness": 3,
              "Raw Price": 4
            }
          }
        }
      ]
    }
  ]

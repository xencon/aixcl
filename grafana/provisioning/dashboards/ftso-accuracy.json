                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "ftso_provider_last_voting_round",
          "legendFormat": "Round"
        }
      ]
    },
    {
      "id": 43,
      "type": "table",
      "title": "Source Transparency \u2014 $pair",
      "description": "Per-source breakdown of the provider's weighted median calculation. weight = normalized exponential-decay weight. staleness = ms since last trade. rawPrice = price before USD conversion (if applicable).",
      "gridPos": {
        "x": 0,
        "y": 38,
        "w": 24,
        "h": 10
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Weight",
            "desc": true
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 4
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Staleness"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dtdurations"
              },
              {
                "id": "decimals",
                "value": 0
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",

#!/usr/bin/env bash
#
# AIXCL Test Runner - Independent test command
# Usage: ./tests/aixcl-test [OPTIONS]
#
# Examples:
#   ./tests/aixcl-test --engine ollama --test 13
#   ./tests/aixcl-test --engine vllm --test 1-14
#   ./tests/aixcl-test --engine all --test all
#

set -e
set -u
set -o pipefail

# Get script directory
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
REPO_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Save our SCRIPT_DIR before test-framework.sh overwrites it
TEST_SCRIPT_DIR="$SCRIPT_DIR"

# Source test framework
source "${TEST_SCRIPT_DIR}/lib/test-framework.sh"
source "${TEST_SCRIPT_DIR}/lib/state-capture.sh"
source "${TEST_SCRIPT_DIR}/lib/cleanup.sh"

# Restore our SCRIPT_DIR
SCRIPT_DIR="$TEST_SCRIPT_DIR"

# Configuration
# shellcheck disable=SC2034
REPORT_FILE="${SCRIPT_DIR}/test-results.md"
COMPARISON_FILE="${SCRIPT_DIR}/comparison-results.md"
TEST_DIR="${SCRIPT_DIR}/command-tests"

# Command options
ENGINE="current"  # current, ollama, vllm, llamacpp, all
MODEL=""
TEST_RANGE="all"
# shellcheck disable=SC2034
VERBOSE=false

# Results tracking
declare -A ENGINE_RESULTS
# shellcheck disable=SC2034
declare -A ENGINE_SCORES
declare -A ENGINE_DURATIONS

# ============================================================================
# Usage & Help
# ============================================================================

show_help() {
    cat << 'EOF'
AIXCL Test Runner - Run tests against specific engines and models

Usage: ./tests/aixcl-test [OPTIONS]

OPTIONS

    -e, --engine <engine>
        Engine to use: ollama, vllm, llamacpp, all, current
        Default: current (uses configured engine from .env)

    -m, --model <model>
        Model name (optional)
        Uses first available model if not specified

    -t, --test <range>
        Test range selection
        Formats: 1 (single), 1-5 (range), 1,3,5 (list), all
        Default: all

    -v, --verbose
        Enable verbose output

    -h, --help
        Show this help message

ENGINES

    ollama      Ollama inference engine (default, CPU/GPU)
    vllm        vLLM inference engine (requires GPU)
    llamacpp    llama.cpp engine (GGUF models)
    all         Run tests against all engines sequentially
    current     Use currently configured engine

EXAMPLES

    ./tests/aixcl-test --test 13
        Run test 13 with current engine

    ./tests/aixcl-test --engine ollama --test 13
        Run test 13 with ollama engine

    ./tests/aixcl-test --engine ollama --model qwen2.5-coder:0.5b --test 13
        Run test 13 with specific engine and model

    ./tests/aixcl-test --engine vllm --test 1-14
        Run tests 1 through 14 with vLLM

    ./tests/aixcl-test --engine all --test 13
        Run test 13 against all engines (comparison mode)

    ./tests/aixcl-test --engine all --test all
        Run all tests against all engines

NOTES

    [*] Tests run sequentially for safety
    [*] Comparison report at tests/comparison-results.md (when using --engine all)
    [*] vLLM tests auto-skip if no GPU detected
    [*] Each engine run is independent with cleanup between runs
EOF
}

# ============================================================================
# Argument Parsing
# ============================================================================

parse_arguments() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -e|--engine)
                ENGINE="$2"
                shift 2
                ;;
            -m|--model)
                MODEL="$2"
                shift 2
                ;;
            -t|--test)
                TEST_RANGE="$2"
                shift 2
                ;;
            -v|--verbose)
                # shellcheck disable=SC2034
                VERBOSE=true
                shift
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            *)
                echo "Error: Unknown option '$1'" >&2
                show_help
                exit 1
                ;;
        esac
    done

    # Validate engine
    if [[ ! "$ENGINE" =~ ^(current|ollama|vllm|llamacpp|all)$ ]]; then
        echo "Error: Invalid engine '$ENGINE'. Must be: current, ollama, vllm, llamacpp, all" >&2
        exit 1
    fi

}

# ============================================================================
# Test Range Parser
# ============================================================================

parse_test_range() {
    local range="$1"
    local -n test_array=$2

    test_array=()

    if [[ "$range" == "all" ]]; then
        # Get all test files sorted
        for test_file in "${TEST_DIR}"/test-*.sh; do
            if [[ -f "$test_file" ]]; then
                test_array+=("$test_file")
            fi
        done
        return
    fi

    # Parse comma-separated values and ranges
    IFS=',' read -ra parts <<< "$range"
    for part in "${parts[@]}"; do
        if [[ "$part" =~ ^([0-9]+)-([0-9]+)$ ]]; then
            # Range: 1-5
            local start="${BASH_REMATCH[1]}"
            local end="${BASH_REMATCH[2]}"
            for ((i=start; i<=end; i++)); do
                local test_file
                test_file=$(printf "%s/test-%02d-*.sh" "$TEST_DIR" "$i")
                for tf in $test_file; do
                    if [[ -f "$tf" ]]; then
                        test_array+=("$tf")
                    fi
                done
            done
        elif [[ "$part" =~ ^[0-9]+$ ]]; then
            # Single number: 13
            local test_file
            test_file=$(printf "%s/test-%02d-*.sh" "$TEST_DIR" "$((10#$part))")
            for tf in $test_file; do
                if [[ -f "$tf" ]]; then
                    test_array+=("$tf")
                fi
            done
        fi
    done
}

# ============================================================================
# Engine Management
# ============================================================================

get_engines_to_run() {
    local _result_var="$1"
    local _engines=""

    if [[ "$ENGINE" == "all" ]]; then
        _engines="ollama vllm llamacpp"
    elif [[ "$ENGINE" == "current" ]]; then
        # Get current engine from .env
        local current
        current=$(grep "^ENGINE=" "${REPO_DIR}/.env" 2>/dev/null | cut -d'=' -f2 || echo "ollama")
        _engines="$current"
    else
        _engines="$ENGINE"
    fi

    eval "$_result_var=\"\$_engines\""
}

set_engine() {
    local engine="$1"
    log_info "Setting engine to: $engine"
    "${REPO_DIR}/aixcl" engine set "$engine" > /dev/null 2>&1 || true
}

start_stack() {
    local engine="$1"
    local model="${2:-}"

    log_info "Starting stack with engine: $engine"
    "${REPO_DIR}/aixcl" stack start --profile sys > /dev/null 2>&1

    # Wait for container
    local container
    container=$(get_engine_container "$engine")
    if [[ -n "$container" ]]; then
        wait_for_container "$container" 60
    fi

    # Load model if specified or get first available
    if [[ -n "$model" ]]; then
        log_info "Loading model: $model"
        "${REPO_DIR}/aixcl" models add "$model" > /dev/null 2>&1 || {
            log_warn "Failed to load model $model, may already exist"
        }
    else
        # Get first available model
        local first_model
        first_model=$("${REPO_DIR}/aixcl" models list 2>/dev/null | awk 'NR>2 && $1 ~ /^(qwen|llama|gpt|codellama|deepseek|mistral)/ {print $1; exit}')
        if [[ -z "$first_model" ]]; then
            # Add default model
            log_info "No model found, adding default..."
            if [[ "$engine" == "ollama" ]]; then
                "${REPO_DIR}/aixcl" models add qwen2.5-coder:0.5b > /dev/null 2>&1
            elif [[ "$engine" == "vllm" ]]; then
                "${REPO_DIR}/aixcl" models add "Qwen/Qwen2.5-Coder-0.5B-Instruct" > /dev/null 2>&1
            elif [[ "$engine" == "llamacpp" ]]; then
                log_warn "No GGUF model available for llama.cpp"
                return 1
            fi
        fi
    fi
}

stop_stack() {
    log_info "Stopping stack..."
    "${REPO_DIR}/aixcl" stack stop > /dev/null 2>&1 || true
}

# ============================================================================
# Test Execution
# ============================================================================

run_single_test() {
    local test_file="$1"
    local test_name
    test_name=$(basename "$test_file" .sh)

    log_info "Running: $test_name"

    # Capture test start time
    local start_time end_time duration
    start_time=$(date +%s)

    if bash "$test_file" 2>&1; then
        end_time=$(date +%s)
        duration=$((end_time - start_time))
        log_success "$test_name passed (${duration}s)"
        return 0
    else
        end_time=$(date +%s)
        duration=$((end_time - start_time))
        log_error "$test_name failed (${duration}s)"
        return 1
    fi
}

run_tests_with_engine() {
    local engine="$1"
    local -n _test_array=$2
    local passed=0
    local failed=0
    local start_time end_time total_duration

    echo ""
    echo "=========================================="
    echo "Testing with engine: $engine"
    echo "=========================================="

    start_time=$(date +%s)

    # Skip vLLM if no GPU
    if [[ "$engine" == "vllm" ]] && ! has_nvidia_gpu; then
        log_warn "No GPU detected, skipping vLLM tests"
        return 0
    fi

    # Setup
    set_engine "$engine"
    start_stack "$engine" "$MODEL"

    # Run tests
    for test_file in "${_test_array[@]}"; do
        if run_single_test "$test_file"; then
            ((passed++))
        else
            ((failed++))
        fi
    done

    # Cleanup
    stop_stack

    end_time=$(date +%s)
    total_duration=$((end_time - start_time))

    # Store results
    ENGINE_RESULTS["$engine"]="$passed/$((passed + failed))"
    ENGINE_DURATIONS["$engine"]="$total_duration"

    echo ""
    log_info "Results for $engine: $passed passed, $failed failed (${total_duration}s)"

    # Return 0 if all tests passed, 1 otherwise
    if [[ $failed -eq 0 ]]; then
        return 0
    else
        return 1
    fi
}

# ============================================================================
# Comparison Report
# ============================================================================

generate_comparison_report() {
    local engines="$1"

    cat > "$COMPARISON_FILE" << EOF
# AIXCL Test Comparison Report

**Generated**: $(date -Iseconds)
**Test Range**: $TEST_RANGE
**Profile**: sys

## Engine Comparison

| Engine | Tests Passed | Duration | Status |
|--------|--------------|----------|--------|
EOF

    for engine in $engines; do
        local result="${ENGINE_RESULTS[$engine]:-N/A}"
        local duration="${ENGINE_DURATIONS[$engine]:-N/A}"
        local status="❌ FAILED"
        
        if [[ "$result" =~ ^[0-9]+/[0-9]+$ ]]; then
            IFS='/' read -ra parts <<< "$result"
            if [[ "${parts[0]}" -gt 0 ]] && [[ "${parts[1]}" -gt 0 ]] && [[ "${parts[0]}" -eq "${parts[1]}" ]]; then
                status="✅ PASSED"
            fi
        fi

        echo "| $engine | $result | ${duration}s | $status |" >> "$COMPARISON_FILE"
    done

    cat >> "$COMPARISON_FILE" << EOF

---

*Report generated by AIXCL Test Runner*
EOF

    log_info "Comparison report written to: $COMPARISON_FILE"
}

# ============================================================================
# Main
# ============================================================================

main() {
    # Show help if no arguments provided
    if [[ $# -eq 0 ]]; then
        show_help
        exit 0
    fi

    parse_arguments "$@"

    echo "=========================================="
    echo "AIXCL Test Runner"
    echo "=========================================="
    echo ""
    echo "Engine:  $ENGINE"
    echo "Model:   ${MODEL:-auto-detect}"
    echo "Tests:   $TEST_RANGE"
    echo "Profile: sys"
    echo ""

    # Parse test range
    local tests=()
    parse_test_range "$TEST_RANGE" tests

    if [[ ${#tests[@]} -eq 0 ]]; then
        log_error "No tests found for range: $TEST_RANGE"
        exit 1
    fi

    log_info "Found ${#tests[@]} test(s) to run"

    # Get engines to run
    local engines
    get_engines_to_run engines

    # Convert space-separated to array
    IFS=' ' read -ra engine_array <<< "$engines"

    # Run tests for each engine
    local total_failed=0
    for engine in "${engine_array[@]}"; do
        if ! run_tests_with_engine "$engine" tests; then
            total_failed=$((total_failed + 1))
        fi
    done

    # Generate comparison report if multiple engines
    if [[ ${#engine_array[@]} -gt 1 ]]; then
        generate_comparison_report "$engines"
    fi

    # Final summary
    echo ""
    echo "=========================================="
    echo "Test Summary"
    echo "=========================================="
    echo ""

    if [[ ${#engine_array[@]} -gt 1 ]]; then
        echo "Results by engine:"
        for engine in "${engine_array[@]}"; do
            echo "  $engine: ${ENGINE_RESULTS[$engine]:-N/A} (${ENGINE_DURATIONS[$engine]:-N/A}s)"
        done
        echo ""
    fi

    if [[ $total_failed -eq 0 ]]; then
        log_success "All tests passed!"
        exit 0
    else
        log_error "Some engines had test failures"
        exit 1
    fi
}

# Run main
main "$@"
